<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_purchase_receipt_invoice_link" model="ir.ui.view">
        <field name="name">account.move.form.purchase.receipt.invoice.link</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_purchase_receipt_picking"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-truck"
                    invisible="move_type not in ('in_invoice', 'in_refund') or not purchase_receipt_picking_id">
                    <field name="purchase_receipt_picking_count" widget="statinfo" string="Receipt"/>
                </button>
            </xpath>
            <xpath expr="//group[@name='accounting_info_group']/field[@name='company_id']" position="after">
                <field
                    name="purchase_receipt_picking_id"
                    readonly="1"
                    invisible="move_type not in ('in_invoice', 'in_refund') or not purchase_receipt_picking_id"/>
            </xpath>
        </field>
    </record>
</odoo>
